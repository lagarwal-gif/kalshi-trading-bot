# Kalshi API (get from demo.kalshi.co → Profile → API Keys)
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Tavily (web search for news)
TAVILY_API_KEY=your-tavily-api-key-here

# Trading config
USE_SANDBOX=true           # set to false to trade with real money
BUDGET_CAP=50.0            # max total dollars invested at any time
MAX_SINGLE_TRADE=10.0      # max dollars per single trade
CYCLE_INTERVAL_MINUTES=30  # how often the agent runs
